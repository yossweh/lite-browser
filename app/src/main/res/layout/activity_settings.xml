<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Ad Block -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@color/surface"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ad Blocker"
                android:textSize="16sp"
                android:textColor="@color/text_primary" />

            <Switch
                android:id="@+id/switchAdBlock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Homepage -->
        <TextView
            android:id="@+id/tvHomepage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Homepage: https://www.google.com"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:padding="12dp"
            android:background="@color/surface"
            android:layout_marginBottom="8dp" />

        <!-- User Agent -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="@color/surface"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Agent"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerUserAgent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Clear Data -->
        <Button
            android:id="@+id/btnClearData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear Browsing Data"
            android:layout_marginBottom="8dp" />

        <!-- Ad Info -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ads help keep this app free. Watch a rewarded ad to remove ads for your current session."
            android:textSize="14sp"
            android:textColor="@color/text_hint"
            android:padding="12dp"
            android:background="@color/surface"
            android:layout_marginBottom="8dp" />

        <!-- Version -->
        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Version: 3.0.0"
            android:textSize="14sp"
            android:textColor="@color/text_hint"
            android:padding="12dp"
            android:background="@color/surface" />

    </LinearLayout>

</ScrollView>
