<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#2D2D2D"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/menu_new_tab"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableStart="@drawable/ic_new_tab"
        android:drawablePadding="16dp"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:text="@string/new_tab"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="@drawable/ripple_item"
        app:drawableTint="#FFFFFF" />

    <TextView
        android:id="@+id/menu_bookmarks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableStart="@drawable/ic_bookmark"
        android:drawablePadding="16dp"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:text="@string/bookmarks"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="@drawable/ripple_item"
        app:drawableTint="#FFFFFF" />

    <TextView
        android:id="@+id/menu_add_bookmark"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableStart="@drawable/ic_bookmark"
        android:drawablePadding="16dp"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:text="@string/add_bookmark"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="@drawable/ripple_item"
        app:drawableTint="#FFFFFF" />

    <TextView
        android:id="@+id/menu_desktop_mode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableStart="@drawable/ic_desktop"
        android:drawablePadding="16dp"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:text="@string/desktop_mode"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="@drawable/ripple_item"
        app:drawableTint="#FFFFFF" />

    <TextView
        android:id="@+id/menu_dark_mode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableStart="@drawable/ic_dark_mode"
        android:drawablePadding="16dp"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:text="@string/dark_mode"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="@drawable/ripple_item"
        app:drawableTint="#FFFFFF" />

    <TextView
        android:id="@+id/menu_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableStart="@drawable/ic_settings"
        android:drawablePadding="16dp"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:text="@string/settings"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="@drawable/ripple_item"
        app:drawableTint="#FFFFFF" />

    <TextView
        android:id="@+id/menu_exit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableStart="@drawable/ic_exit"
        android:drawablePadding="16dp"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:text="@string/exit"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="@drawable/ripple_item"
        app:drawableTint="#FFFFFF" />

</LinearLayout>
